# 富邦 Neo SDK 連線設定
# 複製此檔為 .env 並填入真實資料

# 身分證字號
FUBON_PERSONAL_ID=A123456789

# 網路下單密碼
FUBON_PASSWORD=your_password

# 憑證檔案完整路徑（.pfx 或 .p12）
FUBON_CERT_PATH=/path/to/your/cert.pfx

# 憑證密碼（預設同身分證字號，可留空）
FUBON_CERT_PASSWORD=

# 分行代號（例如：0052）
FUBON_BRANCH_NO=0052

# 帳號（7碼）
FUBON_ACCOUNT_NO=1234567

# API Key / Secret（若有申請）
FUBON_API_KEY=
FUBON_API_SECRET=

# 模擬下單模式（true = 不送出真實委託）
FUBON_DRY_RUN=true

# 無憑證時使用 MockAdapter
MOCK_MODE=false
