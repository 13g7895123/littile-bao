# ───── 富邦 Neo SDK 連線設定 ────────────────────────────────
# 必填（缺一啟動會自動降級為 MockAdapter）
FUBON_PERSONAL_ID=A123456789
FUBON_PASSWORD=your_password
FUBON_CERT_PATH=secrets/A123456789.pfx
FUBON_CERT_PASSWORD=your_cert_password
FUBON_BRANCH_NO=6460
FUBON_ACCOUNT_NO=1234567

# 選用（生產環境建議申請 API Key）
FUBON_API_KEY=
FUBON_API_SECRET=

# 安全開關（強烈建議開發期保持 true）
FUBON_DRY_RUN=true

# 強制使用模擬資料（即使憑證齊全）
MOCK_MODE=false
